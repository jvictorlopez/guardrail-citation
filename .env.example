# Citation Guardrail Engine — Environment Variables
# Copy to .env and fill in values as needed.

# Embedding provider: "hf" (default, local) or "openai"
LLM_PROVIDER=hf

# Matching strategy: "semantic" (default), "keyword", or "hybrid"
MATCH_STRATEGY=semantic

# OpenAI API key (required only if LLM_PROVIDER=openai)
# OPENAI_API_KEY=

# Thresholds
SEMANTIC_THRESHOLD=0.35
KEYWORD_THRESHOLD=0.3
AMBIGUITY_MARGIN=0.05

# HuggingFace model (local, no API key needed)
HF_MODEL=sentence-transformers/all-MiniLM-L6-v2
